      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#DatumReferenceFrameSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#CylindricalToleranceZone"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#applies_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TolerancedFeature"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
