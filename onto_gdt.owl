  <owl:Class rdf:about="http://example.org/onto-gdt#ActualDiameter">
    <rdfs:label xml:lang="en">Actual Diameter</rdfs:label>
    <skos:prefLabel xml:lang="en">Actual diameter</skos:prefLabel>
    <rdfs:comment xml:lang="en">A real property of the feature, not of the drawing.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#inheres_in"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#FeatureOfSize"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#evaluated_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#MeasurementProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#ActualLength">
    <rdfs:label xml:lang="en">Actual Length</rdfs:label>
    <skos:prefLabel xml:lang="en">Actual length</skos:prefLabel>
    <rdfs:comment xml:lang="en">A real property of the part.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#inheres_in"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#evaluated_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#MeasurementProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#ActualThickness">
    <rdfs:label xml:lang="en">Actual Thickness</rdfs:label>
    <skos:prefLabel xml:lang="en">Actual thickness</skos:prefLabel>
    <rdfs:comment xml:lang="en">A real measurable property of the part.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#inheres_in"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
