        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#InspectionProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#VerificationProcess">
    <rdfs:label xml:lang="en">Verification Process</rdfs:label>
    <skos:prefLabel xml:lang="en">Verification process</skos:prefLabel>
    <rdfs:comment xml:lang="en">Verification compares measured characteristic to the imposed condition/specification.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#has_participant"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#has_participant"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Assembly"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
