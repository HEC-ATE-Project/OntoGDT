        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#MeasurementProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AllAroundSpecification">
    <rdfs:label xml:lang="en">All Around Specification</rdfs:label>
    <skos:prefLabel xml:lang="en">All around specification</skos:prefLabel>
    <rdfs:comment xml:lang="en">A symbolic scope indicator.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#applies_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#SurfacePortion"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#part_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#FeatureControlFrame"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AllOverSpecification">
    <rdfs:label xml:lang="en">All Over Specification</rdfs:label>
    <skos:prefLabel xml:lang="en">All over specification</skos:prefLabel>
    <rdfs:comment xml:lang="en">Another symbolic scope indicator.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#applies_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#part_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#FeatureControlFrame"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AngularityDeviation">
    <rdfs:label xml:lang="en">Angularity Deviation</rdfs:label>
    <skos:prefLabel xml:lang="en">Angularity deviation</skos:prefLabel>
    <rdfs:comment xml:lang="en">Depends on a specified angular relation to a datum.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#inheres_in"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TolerancedFeature"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#DatumPlane"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#specified_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AngularityToleranceSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#evaluated_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#MeasurementProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AngularityToleranceSpecification">
    <rdfs:label xml:lang="en">Angularity Tolerance Specification</rdfs:label>
    <skos:prefLabel xml:lang="en">Angularity tolerance specification</skos:prefLabel>
    <rdfs:comment xml:lang="en">Same logic for angularity.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://example.org/onto-gdt#OrientationToleranceSpecification"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#specifies_characteristic"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AngularityDeviation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#DatumReferenceSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TargetAngleSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#references"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#PlanarToleranceZone"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#applies_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TolerancedFeature"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AnnularToleranceZone">
    <rdfs:label xml:lang="en">Annular Tolerance Zone</rdfs:label>
    <skos:prefLabel xml:lang="en">Annular tolerance zone</skos:prefLabel>
    <rdfs:comment xml:lang="en">Circularity examples use an annular region between concentric circles.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#CircularityToleranceSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#Assembly">
    <rdfs:label xml:lang="en">Assembly</rdfs:label>
    <skos:prefLabel xml:lang="en">Assembly</skos:prefLabel>
    <rdfs:comment xml:lang="en">An assembly is made of several material entities taken together; the GPS fiche is explicitly extended to assemblies.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#has_part"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#applies_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#has_participant"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#InspectionProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#has_participant"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#VerificationProcess"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AssociatedCircle">
    <rdfs:label xml:lang="en">Associated Circle</rdfs:label>
    <skos:prefLabel xml:lang="en">Associated circle</skos:prefLabel>
    <rdfs:comment xml:lang="en">BFO top-level has no dedicated circle class; use immaterial entity.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#derived_from"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#NonIdealGeometricElement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#output_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AssociationOperation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#CircularityDeviation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AssociatedCone">
    <rdfs:label xml:lang="en">Associated Cone</rdfs:label>
    <skos:prefLabel xml:lang="en">Associated cone</skos:prefLabel>
    <rdfs:comment xml:lang="en">An ideal cone is immaterial and has no more precise BFO top-level slot.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#derived_from"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#NonIdealGeometricElement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#output_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AssociationOperation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalCharacteristic"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AssociatedCylinder">
    <rdfs:label xml:lang="en">Associated Cylinder</rdfs:label>
    <skos:prefLabel xml:lang="en">Associated cylinder</skos:prefLabel>
    <rdfs:comment xml:lang="en">Same logic for an ideal cylinder.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#derived_from"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#NonIdealGeometricElement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#output_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AssociationOperation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#CylindricityDeviation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#EnvelopeRequirement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AssociatedGeometricElement">
    <rdfs:label xml:lang="en">Associated Geometric Element</rdfs:label>
    <skos:prefLabel xml:lang="en">Associated geometric element</skos:prefLabel>
    <rdfs:comment xml:lang="en">An associated element is ideal and obtained by association from a non-ideal element.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#derived_from"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#NonIdealGeometricElement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#output_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#AssociationOperation"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalCharacteristic"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#AssociatedLine">
    <rdfs:label xml:lang="en">Associated Line</rdfs:label>
    <skos:prefLabel xml:lang="en">Associated line</skos:prefLabel>
    <rdfs:comment xml:lang="en">An ideal line/axis is best captured as a 1D spatial region.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000026"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#derived_from"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#NonIdealGeometricElement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
