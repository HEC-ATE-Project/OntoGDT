        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#EnvelopeRequirement"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#MaximumMaterialConditionModifier">
    <rdfs:label xml:lang="en">Maximum Material Condition Modifier</rdfs:label>
    <skos:prefLabel xml:lang="en">Maximum material condition modifier</skos:prefLabel>
    <rdfs:comment xml:lang="en">The symbol M is part of the specification language, not the actual material state.</rdfs:comment>
