        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#ConformityCondition"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#evaluates"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#evaluates"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalCharacteristic"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

