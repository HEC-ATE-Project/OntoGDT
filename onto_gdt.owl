      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#part_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Part"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#bearer_of"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalCharacteristic"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#referenced_by"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#GeometricalSpecification"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#conforms_to"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#ToleranceZone"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#TotalRunoutToleranceSpecification">
    <rdfs:label xml:lang="en">Total Runout Tolerance Specification</rdfs:label>
    <skos:prefLabel xml:lang="en">Total runout tolerance specification</skos:prefLabel>
    <rdfs:comment xml:lang="en">Same for total runout.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://example.org/onto-gdt#RunoutToleranceSpecification"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#specifies_characteristic"/>
