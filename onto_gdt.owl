        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#Assembly"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#MaximumMaterialCondition">
    <rdfs:label xml:lang="en">Maximum Material Condition</rdfs:label>
    <skos:prefLabel xml:lang="en">Maximum material condition</skos:prefLabel>
    <rdfs:comment xml:lang="en">As a state of a real feature of size, MMC is the condition of maximum material amount.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:subClassOf>
