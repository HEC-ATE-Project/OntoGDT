        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TolerancedFeature"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/onto-gdt#TotalRunoutValue">
    <rdfs:label xml:lang="en">Total Runout Value</rdfs:label>
    <skos:prefLabel xml:lang="en">Total runout value</skos:prefLabel>
    <rdfs:comment xml:lang="en">Same logic for the whole surface over 360 degrees.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://example.org/onto-gdt#inheres_in"/>
        <owl:someValuesFrom rdf:resource="http://example.org/onto-gdt#TolerancedFeature"/>
